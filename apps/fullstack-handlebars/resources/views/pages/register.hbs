{{#> layout}}
  <h1>Register</h1>

  {{#if error}}
    <div style="padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; background: #fee2e2; color: #991b1b; border: 1px solid #fecaca;">
      {{error}}
    </div>
  {{/if}}

  <div class="card" style="max-width: 400px;">
    <form method="POST" action="/register">
      <label>Name</label>
      <input type="text" name="name" placeholder="Alice" required>

      <label>Email</label>
      <input type="email" name="email" placeholder="alice@tekir.dev" required>

      <label>Password</label>
      <input type="password" name="password" placeholder="Min 6 characters" required minlength="6">

      <button type="submit" class="btn" style="margin-top: 12px; width: 100%;">Register</button>
    </form>
    <p class="text-muted" style="margin-top: 12px;">
      Already have an account? <a href="/login">Login</a>
    </p>
  </div>
{{/layout}}
