{{#> layout}}
  <h1>Login</h1>

  {{#if error}}
    <div style="padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; background: #fee2e2; color: #991b1b; border: 1px solid #fecaca;">
      {{error}}
    </div>
  {{/if}}

  <div class="card" style="max-width: 400px;">
    <form method="POST" action="/login">
      <label>Email</label>
      <input type="email" name="email" placeholder="alice@tekir.dev" required>

      <label>Password</label>
      <input type="password" name="password" placeholder="secret" required>

      <button type="submit" class="btn" style="margin-top: 12px; width: 100%;">Login</button>
    </form>
    <p class="text-muted" style="margin-top: 12px;">
      Don't have an account? <a href="/register">Register</a>
    </p>
  </div>
{{/layout}}
