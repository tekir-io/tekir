{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "@types/bun"
    ],
    "paths": {
      "@tekir/*": [
        "../../packages/tekir-*/src"
      ],
      "#services": [
        "./services.ts"
      ],
      "#env": [
        "./env.ts"
      ],
      "~/*": [
        "./app/*"
      ],
      "#config/*": [
        "./config/*"
      ],
      "#resources/*": [
        "./resources/*"
      ]
    }
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
