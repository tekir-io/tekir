{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": [
      "@types/bun"
    ],
    "paths": {
      "~/*": [
        "./core/*"
      ],
      "#services": [
        "./services.ts"
      ],
      "#types": [
        "./types.ts"
      ],
      "#env": [
        "./env.ts"
      ],
      "#config/*": [
        "./config/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts"
  ]
}
