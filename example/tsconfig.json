{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@types/bun"],
    "paths": {
      "@tekir/*": ["../packages/tekir-*/src"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
