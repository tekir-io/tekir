{
  "name": "tekir-framework",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "oxc-parser": "^0.128.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "author": "dev@tekir.io",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "turbo dev",
    "test": "bun test packages/ && bun test example/",
    "test:packages": "bun test packages/",
    "test:example": "bun test example/",
    "lint": "eslint packages/*/src/",
    "lint:fix": "eslint packages/*/src/ --fix",
    "check": "bun run lint && bun run test"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "example"
  ],
  "overrides": {
    "postcss": ">=8.5.10",
    "esbuild": ">=0.28.1",
    "brace-expansion": ">=5.0.7",
    "form-data": ">=4.0.6",
    "uuid": ">=11.1.1"
  }
}
