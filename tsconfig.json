{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@types/bun"],
    "paths": {
      "@tekir/*": ["./packages/tekir-*/src"]
    }
  },
  "include": ["packages/*/src/**/*", "packages/*/tests/**/*", "eslint.config.ts"],
  "exclude": ["node_modules", "**/dist", "apps", "packages/create-tekir-app/src/templates"]
}
