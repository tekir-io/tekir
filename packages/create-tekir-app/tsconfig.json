{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "@types/bun"
    ],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true
  },
  "include": [
    "src/index.ts"
  ],
  "exclude": [
    "src/templates",
    "dist"
  ]
}
