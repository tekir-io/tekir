{
  "name": "@tekir/next",
  "version": "0.1.5",
  "description": "Next.js integration middleware for tekir",
  "author": "dev@tekir.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tekir-io/tekir.git",
    "directory": "packages/tekir-next"
  },
  "homepage": "https://github.com/tekir-io/tekir/tree/main/packages/tekir-next",
  "keywords": [
    "tekir",
    "bun",
    "typescript",
    "framework",
    "nodejs",
    "fullstack"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@tekir/core": "^0.1.35"
  },
  "peerDependencies": {
    "next": ">=14.0.0 <17.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --noEmit false",
    "prepublishOnly": "bun run build"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
