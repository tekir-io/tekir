{
  "name": "@tekir/shield",
  "version": "0.1.2",
  "description": "Security middleware with CSRF, CSP, XSS protection",
  "author": "dev@tekir.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tekir-io/tekir.git",
    "directory": "packages/tekir-shield"
  },
  "homepage": "https://github.com/tekir-io/tekir/tree/main/packages/tekir-shield",
  "keywords": [
    "tekir",
    "bun",
    "typescript",
    "framework",
    "nodejs",
    "fullstack"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --noEmit false",
    "prepublishOnly": "bun run build"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@tekir/limiter": "^0.1.1"
  },
  "peerDependenciesMeta": {
    "@tekir/limiter": {
      "optional": true
    }
  }
}
