{
  "name": "@tekir/core",
  "version": "0.1.35",
  "description": "Core tekir framework with routing, HTTP, and WebSockets",
  "author": "dev@tekir.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tekir-io/tekir.git",
    "directory": "packages/tekir-core"
  },
  "homepage": "https://github.com/tekir-io/tekir/tree/main/packages/tekir-core",
  "keywords": [
    "tekir",
    "bun",
    "typescript",
    "framework",
    "nodejs",
    "fullstack"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@tekir/config": "^0.1.3",
    "@tekir/logger": "^0.1.3",
    "@tekir/runtime": "^0.1.5",
    "@tekir/commands": "^0.1.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "oxc-parser": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "oxc-parser": {
      "optional": true
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --noEmit false",
    "prepublishOnly": "bun run build"
  }
}
